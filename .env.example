# Nome da aplicação exibido em logs e documentação
APP_NAME=icd11-code-normalizer

# Ambiente atual da aplicação
APP_ENV=development

# Porta HTTP exposta pela API
APP_PORT=8000

# Token bearer usado para autenticar o endpoint POST /normalize
AUTH_TOKEN=change-me

# Caminho do banco SQLite persistido localmente
SQLITE_PATH=/data/app.db

# URL oficial do ZIP da WHO usado no seed da Simple Tabulation
SIMPLE_TABULATION_ZIP_URL=https://icdcdn.who.int/static/releasefiles/2024-01/SimpleTabulation-ICD-11-MMS-en.zip

# Chave de API usada para autenticar chamadas ao OpenRouter
OPENROUTER_API_KEY=change-me

# Endpoint base compatível com OpenAI exposto pelo OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Modelo padrão usado para refraseação via OpenRouter
OPENROUTER_MODEL=openrouter/free

# Timeout máximo em segundos para chamadas ao provedor LLM
LLM_TIMEOUT_SECONDS=45

# Versão do prompt usada para invalidação de cache quando houver mudança de prompt
PROMPT_VERSION=v1

# Base URL da API do Open Concept Lab usada para criar ou atualizar conceitos
OCL_BASE_URL=https://api.openconceptlab.org

# Token da API do Open Concept Lab usado para sincronizar conceitos normalizados
OCL_TOKEN=

# Source do OCL onde os conceitos normalizados devem ser criados ou atualizados
OCL_LOOKUP_SOURCE=/orgs/OpenMRS-OCL-Squad/sources/ICD-11-WHO-Mapper/

# Nível mínimo de log emitido em stdout pela aplicação
LOG_LEVEL=INFO
